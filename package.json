{
  "name": "p2p-message",
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-based P2P encrypted chat with manual invite signaling",
  "scripts": {
    "build": "node scripts/build.mjs",
    "preview": "node scripts/preview.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "test": "vitest run",
    "test:ci": "node scripts/test-ci.mjs",
    "test:e2e": "npx playwright test --project=chromium",
    "test:e2e:headed": "npx playwright test --project=chromium --headed",
    "test:security": "npx playwright test security-audit --project=chromium",
    "test:security:headed": "npx playwright test security-audit --project=chromium --headed",
    "interceptor": "node message-interceptor/main.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "vitest": "^3.0.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.5.4"
  }
}
